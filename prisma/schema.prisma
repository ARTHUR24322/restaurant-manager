generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Restaurant {
  id                        String            @id @default(cuid())
  nom                       String
  slug                      String?           @unique
  email                     String
  ville                     String            @default("Lubumbashi")
  plan                      String            @default("STANDARD")
  logoUrl                   String?
  adminPassword             String
  pinCode                   String            @default("0000")
  active                    Boolean           @default(true)
  billingCycle              String            @default("monthly")
  monthlyPrice              Float             @default(0)
  subscriptionEnd           DateTime?
  preferredTheme            String            @default("dark")
  createdAt                 DateTime          @default(now())
  telephone                 String?
  tauxChange                Float             @default(2800)
  sessionVersion            Int               @default(1)
  pays                      String            @default("République Démocratique du Congo")
  whatsappAccessToken       String?
  whatsappBusinessAccountId String?
  whatsappEnabled           Boolean           @default(false)
  whatsappPhoneNumberId     String?
  isBoutiqueEnabled         Boolean           @default(false)
  boutiqueSlug              String?           @unique
  // Multi-site: lien parent-enfant
  parentId                  String?
  parent                    Restaurant?       @relation("RestaurantChildren", fields: [parentId], references: [id])
  children                  Restaurant[]      @relation("RestaurantChildren")
  // Sécurité: première connexion
  firstLogin                Boolean           @default(true)
  articles                  ArticleStock[]
  clientRewards             ClientReward[]
  commandes                 Commande[]
  emplacements              Emplacement[]
  fournisseurs              Fournisseur[]
  loyaltyConfig             LoyaltyConfig?
  loyaltyCustomers          LoyaltyCustomer[]
  mouvements                MouvementStock[]
  notifications             Notification[]
  plats                     Plat[]
  rewardCatalog             RewardCatalog[]
  subscriptionLogs          SubscriptionLog[]
  visites                   Visite[]
  employes                  Employe[]
}

model ArticleStock {
  id            String           @id @default(cuid())
  nom           String
  reference     String?          @unique
  codeBarres    String?          @unique
  description   String?
  categorie     String?          @default("GENERAL")
  prixAchat     Float            @default(0)
  prixVente     Float?
  stockActuel   Float            @default(0)
  stockMin      Float            @default(5)
  stockMax      Float?
  unite         String           @default("Unité")
  restaurantId  String
  emplacementId String?
  fournisseurId String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  emplacement   Emplacement?     @relation(fields: [emplacementId], references: [id])
  fournisseur   Fournisseur?     @relation(fields: [fournisseurId], references: [id])
  restaurant    Restaurant       @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  mouvements    MouvementStock[]
  recetteItems  RecetteItem[]

  @@index([restaurantId])
}

model Emplacement {
  id           String         @id @default(cuid())
  nom          String
  description  String?
  restaurantId String
  articles     ArticleStock[]
  restaurant   Restaurant     @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
}

model Fournisseur {
  id           String         @id @default(cuid())
  nom          String
  contact      String?
  telephone    String?
  email        String?
  adresse      String?
  restaurantId String
  articles     ArticleStock[]
  restaurant   Restaurant     @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
}

model MouvementStock {
  id           String       @id @default(cuid())
  type         String
  quantite     Float
  prixUnitaire Float?
  note         String?
  articleId    String
  restaurantId String
  createdAt    DateTime     @default(now())
  article      ArticleStock @relation(fields: [articleId], references: [id], onDelete: Cascade)
  restaurant   Restaurant   @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
}

model Plat {
  id              String         @id @default(cuid())
  nom             String
  description     String?
  prixUsd         Float
  image           String
  categorie       String
  disponible      Boolean        @default(true)
  restaurantId    String
  devise          String         @default("USD")
  isLoyaltyReward Boolean        @default(false)
  isAvailableOnline Boolean      @default(false)
  items           CommandeItem[]
  options         Option[]
  restaurant      Restaurant     @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  recetteItems    RecetteItem[]

  @@index([restaurantId])
}

model Option {
  id     String @id @default(cuid())
  nom    String
  type   String
  choix  String
  platId String
  plat   Plat   @relation(fields: [platId], references: [id], onDelete: Cascade)
}

model Commande {
  id             String         @id @default(cuid())
  table          String
  client         String?
  statut         String         @default("PENDING")
  noteSpeciale   String?
  tauxChange     Float
  totalUsd       Float
  paiementStatus String         @default("UNPAID")
  transactionId  String?
  restaurantId   String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  phone          String?
  adresseLivraison String?
  livreur        String?
  stockDeducted  Boolean        @default(false)
  restaurant     Restaurant     @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  items          CommandeItem[]

  // Multi-personnel
  createurId     String?
  caissierId     String?
  cuisinierId    String?
  
  createur       Employe?       @relation("EmployeCreateur", fields: [createurId], references: [id])
  caissier       Employe?       @relation("EmployeCaisse", fields: [caissierId], references: [id])
  cuisinier      Employe?       @relation("EmployeCuisine", fields: [cuisinierId], references: [id])

  @@index([restaurantId])
}

model CommandeItem {
  id         String   @id @default(cuid())
  commandeId String
  platId     String
  quantite   Int      @default(1)
  options    String
  commande   Commande @relation(fields: [commandeId], references: [id], onDelete: Cascade)
  plat       Plat     @relation(fields: [platId], references: [id], onDelete: Cascade)

  @@index([commandeId])
  @@index([platId])
}

model Visite {
  id           String     @id @default(cuid())
  restaurantId String
  table        String
  createdAt    DateTime   @default(now())
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
}

model DemandeAbonnement {
  id              String   @id @default(cuid())
  nomRestaurant   String
  nomProprietaire String
  email           String
  telephone       String
  ville           String   @default("Lubumbashi")
  plan            String
  cycle           String
  montant         Float
  statut          String   @default("EN_ATTENTE")
  createdAt       DateTime @default(now())
}

model SystemConfig {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model SubscriptionLog {
  id           String     @id @default(cuid())
  restaurantId String
  oldPlan      String?
  newPlan      String
  type         String
  amount       Float
  monthlyPrice Float
  createdAt    DateTime   @default(now())
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
}

model Notification {
  id           String     @id @default(cuid())
  restaurantId String
  title        String
  message      String
  type         String     @default("INFO")
  read         Boolean    @default(false)
  createdAt    DateTime   @default(now())
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
}

model RecoveryRequest {
  id            String   @id @default(cuid())
  nomRestaurant String
  email         String
  telephone     String
  statut        String   @default("EN_ATTENTE")
  createdAt     DateTime @default(now())
}

model SupportMessage {
  id        String   @id @default(cuid())
  nom       String
  email     String
  telephone String
  message   String
  sujet     String   @default("SUPPORT")
  statut    String   @default("NON_LU")
  createdAt DateTime @default(now())
}

model RecetteItem {
  id        String       @id @default(cuid())
  platId    String
  articleId String
  quantite  Float
  article   ArticleStock @relation(fields: [articleId], references: [id], onDelete: Cascade)
  plat      Plat         @relation(fields: [platId], references: [id], onDelete: Cascade)

  @@index([platId])
  @@index([articleId])
}

model LoyaltyConfig {
  id              String     @id @default(cuid())
  restaurantId    String     @unique
  pointsPerUsd    Int        @default(1)
  rewardThreshold Int        @default(100)
  rewardDescription String?
  isActive        Boolean    @default(true)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  restaurant      Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
}

model LoyaltyCustomer {
  id                String               @id @default(cuid())
  phone             String
  points            Int                  @default(0)
  restaurantId      String
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  name              String               @default("Client")
  totalPointsEarned Int                  @default(0)
  rewards           ClientReward[]
  restaurant        Restaurant           @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  transactions      LoyaltyTransaction[]

  @@unique([phone, restaurantId])
  @@index([restaurantId])
}

model LoyaltyTransaction {
  id         String          @id @default(cuid())
  customerId String
  type       String
  points     Int
  commandeId String?
  note       String?
  createdAt  DateTime        @default(now())
  customer   LoyaltyCustomer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

model RewardCatalog {
  id             String     @id @default(cuid())
  restaurantId   String
  type           String
  requiredPoints Int
  productId      String?
  discountValue  Float?
  allowedDays    String[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  restaurant     Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
}

model ClientReward {
  id           String          @id @default(cuid())
  customerId   String
  restaurantId String
  type         String
  productId    String?
  promoCode    String?         @unique
  discountValue Float?
  isUsed       Boolean         @default(false)
  allowedDays  String[]
  expiresAt    DateTime?
  createdAt    DateTime        @default(now())
  customer     LoyaltyCustomer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  restaurant   Restaurant      @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([restaurantId])
}

model SecurityLog {
  id        String   @id @default(cuid())
  email     String
  ipAddress String?
  userAgent String?
  status    String   // "SUCCESS" | "FAILED"
  reason    String?
  source    String   @default("MANAGER") // "MANAGER" | "SUPER_ADMIN"
  createdAt DateTime @default(now())
}

model ActionLog {
  id          String   @id @default(cuid())
  action      String   // "TOGGLE_SUBSCRIPTION", "DELETE_RESTAURANT", "MAINTENANCE_TOGGLE", etc.
  details     String
  performedBy String
  targetId    String?
  ipAddress   String?
  createdAt   DateTime @default(now())
}

enum RoleEmploye {
  MANAGER
  CAISSIER
  CUISINIER
  SERVEUR
  LIVREUR
}

model Employe {
  id             String        @id @default(cuid())
  nom            String
  codePin        String
  role           RoleEmploye
  actif          Boolean       @default(true)
  restaurantId   String
  restaurant     Restaurant    @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  
  commandesCrees   Commande[]  @relation("EmployeCreateur")
  commandesCaisse  Commande[]  @relation("EmployeCaisse")
  commandesCuisine Commande[]  @relation("EmployeCuisine")
  sessionsCaisse   ShiftCaisse[]
  
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([restaurantId, codePin])
  @@index([restaurantId])
}

model ShiftCaisse {
  id             String    @id @default(cuid())
  employeId      String
  restaurantId   String
  heureOuverture DateTime  @default(now())
  heureFermeture DateTime?
  fondsInitial   Float     @default(0)
  fondsFinal     Float?
  
  employe        Employe   @relation(fields: [employeId], references: [id], onDelete: Cascade)
  
  @@index([employeId])
  @@index([restaurantId])
}
