generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Restaurant {
  id              String     @id @default(cuid())
  nom             String
  slug            String?    @unique
  email           String
  telephone       String?
  ville           String     @default("Lubumbashi")
  plan            String     @default("STANDARD")
  logoUrl         String?
  adminPassword   String
  pinCode         String     @default("0000")
  active          Boolean    @default(true)
  billingCycle    String     @default("monthly")
  monthlyPrice    Float      @default(0)
  subscriptionEnd DateTime?
  preferredTheme  String     @default("dark")
  tauxChange      Float      @default(2800)
  pays            String     @default("République Démocratique du Congo")
  sessionVersion  Int        @default(1)
  createdAt       DateTime   @default(now())
  commandes       Commande[]
  plats           Plat[]
  visites         Visite[]

  // Stock Relations
  articles         ArticleStock[]
  emplacements     Emplacement[]
  fournisseurs     Fournisseur[]
  mouvements       MouvementStock[]
  subscriptionLogs SubscriptionLog[]
  notifications    Notification[]
  loyaltyConfig    LoyaltyConfig?
  loyaltyCustomers LoyaltyCustomer[]
}

model ArticleStock {
  id          String  @id @default(cuid())
  nom         String
  reference   String? @unique
  codeBarres  String? @unique
  description String?
  categorie   String? @default("GENERAL")
  prixAchat   Float   @default(0)
  prixVente   Float?
  stockActuel Float   @default(0)
  stockMin    Float   @default(5)
  stockMax    Float?
  unite       String  @default("Unité") // Kg, L, Bouteille, etc.

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  emplacementId String?
  emplacement   Emplacement? @relation(fields: [emplacementId], references: [id], onDelete: SetNull)

  fournisseurId String?
  fournisseur   Fournisseur? @relation(fields: [fournisseurId], references: [id], onDelete: SetNull)

  mouvements   MouvementStock[]
  recetteItems RecetteItem[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([restaurantId])
}

model Emplacement {
  id          String  @id @default(cuid())
  nom         String
  description String?

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  articles ArticleStock[]

  @@index([restaurantId])
}

model Fournisseur {
  id        String  @id @default(cuid())
  nom       String
  contact   String?
  telephone String?
  email     String?
  adresse   String?

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  articles ArticleStock[]

  @@index([restaurantId])
}

model MouvementStock {
  id           String  @id @default(cuid())
  type         String // ENTREE, SORTIE, PERTE, RETOUR, AJUSTEMENT
  quantite     Float
  prixUnitaire Float? // Prix lors du mouvement
  note         String?

  articleId String
  article   ArticleStock @relation(fields: [articleId], references: [id], onDelete: Cascade)

  restaurantId String
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([restaurantId])
}

model Plat {
  id              String         @id @default(cuid())
  nom             String
  description     String?
  prixUsd         Float
  devise          String         @default("USD")
  image           String
  categorie       String
  disponible      Boolean        @default(true)
  isLoyaltyReward Boolean        @default(false)
  restaurantId    String
  items           CommandeItem[]
  options         Option[]
  recetteItems    RecetteItem[]
  restaurant      Restaurant     @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
}

model Option {
  id     String @id @default(cuid())
  nom    String
  type   String
  choix  String
  platId String
  plat   Plat   @relation(fields: [platId], references: [id], onDelete: Cascade)
}

model Commande {
  id             String         @id @default(cuid())
  table          String
  client         String?
  phone          String?
  statut         String         @default("PENDING")
  noteSpeciale   String?
  tauxChange     Float
  totalUsd       Float
  paiementStatus String         @default("UNPAID")
  transactionId  String?
  restaurantId   String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  restaurant     Restaurant     @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  items          CommandeItem[]

  @@index([restaurantId])
}

model CommandeItem {
  id         String   @id @default(cuid())
  commandeId String
  platId     String
  quantite   Int      @default(1)
  options    String
  plat       Plat     @relation(fields: [platId], references: [id], onDelete: Cascade)
  commande   Commande @relation(fields: [commandeId], references: [id], onDelete: Cascade)

  @@index([commandeId])
  @@index([platId])
}

model Visite {
  id           String     @id @default(cuid())
  restaurantId String
  table        String
  createdAt    DateTime   @default(now())
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
}

model DemandeAbonnement {
  id              String   @id @default(cuid())
  nomRestaurant   String
  nomProprietaire String
  email           String
  telephone       String
  ville           String   @default("Lubumbashi")
  plan            String
  cycle           String
  montant         Float
  statut          String   @default("EN_ATTENTE")
  createdAt       DateTime @default(now())
}

model SystemConfig {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model SubscriptionLog {
  id           String     @id @default(cuid())
  restaurantId String
  oldPlan      String?
  newPlan      String
  type         String // UPGRADE, DOWNGRADE, RENEWAL, NEW
  amount       Float // Total amount paid for this period
  monthlyPrice Float // Calculated MRR
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@index([restaurantId])
}

model Notification {
  id           String   @id @default(cuid())
  restaurantId String
  title        String
  message      String
  type         String   @default("INFO") // INFO, WARNING, SUCCESS, URGENT
  read         Boolean  @default(false)
  createdAt    DateTime @default(now())

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
}

model RecoveryRequest {
  id            String   @id @default(cuid())
  nomRestaurant String
  email         String
  telephone     String
  statut        String   @default("EN_ATTENTE") // EN_ATTENTE, TRAITE, REJETE
  createdAt     DateTime @default(now())
}

model SupportMessage {
  id        String   @id @default(cuid())
  nom       String
  email     String
  telephone String
  message   String
  sujet     String   @default("SUPPORT") // CENTRE_AIDE, CONTACT, WHATSAPP, etc.
  statut    String   @default("NON_LU") // NON_LU, LU, TRAITE
  createdAt DateTime @default(now())
}

model RecetteItem {
  id        String @id @default(cuid())
  platId    String
  articleId String
  quantite  Float // Quantité de l'article utilisée pour ce plat

  plat    Plat         @relation(fields: [platId], references: [id], onDelete: Cascade)
  article ArticleStock @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([platId])
  @@index([articleId])
}

model LoyaltyConfig {
  id                String     @id @default(cuid())
  restaurantId      String     @unique
  restaurant        Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  pointsPerUsd      Int        @default(1)
  rewardThreshold   Int        @default(100) // Points needed for a gift
  rewardDescription String?    @default("Un cadeau offert !")
  isActive          Boolean    @default(true)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
}

model LoyaltyCustomer {
  id           String               @id @default(cuid())
  phone        String
  name         String               @default("Client")
  points       Int                  @default(0)
  restaurantId String
  restaurant   Restaurant           @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  transactions LoyaltyTransaction[]
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@unique([phone, restaurantId])
  @@index([restaurantId])
}

model LoyaltyTransaction {
  id         String          @id @default(cuid())
  customerId String
  customer   LoyaltyCustomer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  type       String // EARN, REDEEM
  points     Int
  commandeId String? // Link to order if EARN
  note       String?
  createdAt  DateTime        @default(now())

  @@index([customerId])
}
